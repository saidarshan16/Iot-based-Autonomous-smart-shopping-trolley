# =====================================================
# BACK BUTTON
# =====================================================

def back_to_scan():

    payment_frame.pack_forget()

    scan_frame.pack(fill="both", expand=True)

    barcode_entry.focus_force()

back_btn = tk.Button(
    button_container,
