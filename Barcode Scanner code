)

qr_label.pack(pady=3)

# =====================================================
# GENERATE QR
# =====================================================

def generate_qr(amount):

    upi_link = f"upi://pay?pa=saidarshan55m@okaxis&pn=SmartCart&am={amount}&cu=INR"

    qr = qrcode.make(upi_link)

    qr = qr.resize((130, 130))

    qr_photo = ImageTk.PhotoImage(qr)

    qr_label.config(image=qr_photo)

    qr_label.image = qr_photo

